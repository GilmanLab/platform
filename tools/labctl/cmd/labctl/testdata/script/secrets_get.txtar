env SOPS_AGE_KEY=AGE-SECRET-KEY-1NK7RF4CDV8HQXZZYJKRR3T3K6Z3QXRYF6F5WZW3Q2FC5FZ8FKDQQVVTSEG
env GLAB_SECRETS_DIR=$WORK/secrets

# Full local document decrypts without printing SOPS metadata.
exec labctl secrets get network/keycloak.sops.yaml
stdout 'database:'
stdout 'username: admin'
stdout 'password: test-secret'
stdout 'servers:'
! stdout 'sops:'
! stderr .

# JSON output converts the decrypted YAML document.
exec labctl secrets get network/keycloak.sops.yaml --format json
stdout '"database":'
stdout '"username":"admin"'
stdout '"password":"test-secret"'
stdout '"servers":'
stdout '"port":8080'
! stderr .

# Output paths write files without printing secret data.
exec labctl secrets get network/keycloak.sops.yaml --output secret.yaml
! stdout .
! stderr .
cmp secret.yaml expected-keycloak.yaml

exec labctl secrets get network/keycloak.sops.yaml --format json --output secret.json
! stdout .
! stderr .
cmp secret.json expected-keycloak.json

! exec labctl secrets get network/keycloak.sops.yaml --format toml
stderr 'invalid output format "toml"'

! exec labctl secrets get network/keycloak.sops.yaml --output missing/secret.yaml
stderr 'output parent directory'

# Scalar field selection prints raw scalar text.
exec labctl secrets get network/keycloak.sops.yaml --field /database/username
stdout '^admin\n$'
! stderr .

# Structured field selection prints YAML.
exec labctl secrets get network/keycloak.sops.yaml --field /servers/0
stdout '^name: keycloak\nport: 8080\n$'
! stderr .

# Path traversal is rejected before any source fetch.
! exec labctl secrets get ../keycloak.sops.yaml
stderr 'must not contain'

# Configured local source is authoritative; missing local files do not fall back to GitHub.
! exec labctl secrets get missing.sops.yaml
stderr 'read local encrypted secret'

# GitHub source can use an env-only manual token with the fake Contents API.
env GLAB_SECRETS_DIR=
env LABCTL_GITHUB_TOKEN=ghs_test
exec labctl secrets get network/keycloak.sops.yaml --source github --ref feature --field /database/password
stdout '^test-secret\n$'
! stderr .

-- expected-keycloak.yaml --
database:
    username: admin
    password: test-secret
servers:
    - name: keycloak
      port: 8080
-- expected-keycloak.json --
{"database":{"password":"test-secret","username":"admin"},"servers":[{"name":"keycloak","port":8080}]}
